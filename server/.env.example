# ═══════════════════════════════════════════════════
# SERVER ENVIRONMENT VARIABLES
# Copy this file to .env for local dev
# For Railway: set these in the Railway dashboard
# ═══════════════════════════════════════════════════

PORT=5000
NODE_ENV=production

# ── DATABASE ─────────────────────────────────────
# PRODUCTION (Supabase): use DATABASE_URL only
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# LOCAL DEV only (ignore if using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_saas
DB_USER=postgres
DB_PASSWORD=your_local_password

# ── JWT ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────
# Your Vercel frontend URL (set AFTER deploying frontend)
CLIENT_URL=https://your-app.vercel.app
