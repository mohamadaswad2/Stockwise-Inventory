# ════════════════════════════════════════
# SERVER ENV — set these in Railway dashboard
# ════════════════════════════════════════

PORT=5000
NODE_ENV=production

# Database (Supabase Session Pooler URL)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-x-ap-southeast-1.pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=generate_with_node_crypto_64_bytes
JWT_EXPIRES_IN=7d

# CORS — your Vercel URL
CLIENT_URL=https://your-app.vercel.app

# Email (Gmail SMTP)
# For Gmail: enable 2FA → App Passwords → generate password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password

# Admin account (used by db:seed)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourSecureAdminPassword123!
